# =====================================================================
# AltPool — variables d'environnement de production
# Copier ce fichier en .env.prod et remplir avec des valeurs FORTES
# JAMAIS commiter .env.prod dans Git !
# =====================================================================

# ---- Postgres -------------------------------------------------------
DB_NAME=altpool
DB_USER=altpool
# Génère un mot de passe fort : openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ---- JWT secret -----------------------------------------------------
# Génère via : openssl rand -base64 64
JWT_SECRET=CHANGE_ME_LONG_BASE64_SECRET_AT_LEAST_64_CHARS

# ---- Domaine (utilisé dans nginx.conf, tu dois aussi remplacer
# 'altpool.example.com' dans deploy/nginx/altpool.conf) --------------
DOMAIN=altpool.example.com
ADMIN_EMAIL=admin@example.com
